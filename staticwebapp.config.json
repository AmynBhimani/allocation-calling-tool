{
  "auth": {
    "rolesSource": "/api/roles",
    "identityProviders": {
      "customOpenIdConnectProviders": {
        "externalid": {
          "registration": {
            "clientIdSettingName": "EXTERNALID_CLIENT_ID",
            "clientCredential": { "clientSecretSettingName": "EXTERNALID_CLIENT_SECRET" },
            "openIdConnectConfiguration": {
              "wellKnownOpenIdConfiguration": "https://REPLACE_TENANT_GUID.ciamlogin.com/REPLACE_TENANT_GUID/v2.0/.well-known/openid-configuration"
            }
          },
          "login": { "nameClaimType": "email", "scopes": ["openid", "profile", "email"] }
        }
      }
    }
  },
  "routes": [
    { "route": "/.auth/login/github", "statusCode": 404 },
    { "route": "/.auth/login/aad", "statusCode": 404 },
    { "route": "/api/ping", "allowedRoles": ["anonymous"] },
    { "route": "/unauthorized.html", "allowedRoles": ["anonymous"] },
    { "route": "/api/seed", "allowedRoles": ["superadmin"] },
    { "route": "/api/sync", "allowedRoles": ["superadmin"] },
    { "route": "/api/volunteers", "allowedRoles": ["superadmin", "admin", "dutyteam"] },
    { "route": "/api/*", "allowedRoles": ["superadmin", "admin", "dutyteam", "quarterback", "caller"] },
    { "route": "/*", "allowedRoles": ["superadmin", "admin", "dutyteam", "quarterback", "caller"] }
  ],
  "responseOverrides": {
    "401": { "redirect": "/.auth/login/externalid", "statusCode": 302 },
    "403": { "redirect": "/unauthorized.html", "statusCode": 302 }
  },
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/*.css", "/*.js", "/unauthorized.html"]
  },
  "globalHeaders": { "cache-control": "no-store" },
  "platform": { "apiRuntime": "node:18" }
}
